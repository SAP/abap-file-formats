{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "http://sap.com/sap/bw/ana/abi/QuickAction",
  "type": "object",
  "description": "Analytical Quick Action",
  "properties": {
    "$schema": {
      "type": "string",
      "enum": ["http://sap.com/sap/bw/ana/abi/QuickAction"]
    },
    "name": {
      "type": "string",
      "pattern": "^[A-Z_][A-Za-z0-9_]{0,29}$",
      "description": "Name of the Command. Must be unique per Booklet."
    },
    "constants": {
      "type": "object",
      "minProperties": 1,
      "unevaluatedProperties": false,
      "patternProperties": {
        "^[A-Z][A-Za-z0-9]{0,59}$": {
          "allOf": [
            {
              "$ref": "#/$defs/parameter"
            },
            {
              "properties": {
                "value": {
                  "type": "string"
                }
              },
              "required": ["value"]
            }
          ],
          "unevaluatedProperties": false,
          "description": "Metadata and Value of the Constant."
        }
      },
      "description": "Optional: List of Constants to be used as Parameter in the steps."
    },
    "inputParameters": {
      "type": "object",
      "minProperties": 1,
      "unevaluatedProperties": false,
      "patternProperties": {
        "^[A-Z][A-Za-z0-9]{0,59}$": {
          "$ref": "#/$defs/parameter",
          "unevaluatedProperties": false
        }
      },
      "description": "Optional: List of Parameters to be passed when calling this action. Only use for Hidden actions."
    },
    "dataProviderDelegation": {
      "type": "array",
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/step",
            "unevaluatedProperties": false
          },
          {
            "properties": {
              "commandType": {
                "type": "string",
                "enum": ["Custom"]
              }
            }
          }
        ]
      },
      "minItems": 2,
      "maxItems": 2,
      "description": "Delegation Steps for multiple DataProviders."
    },
    "steps": {
      "type": "object",
      "minProperties": 1,
      "unevaluatedProperties": false,
      "patternProperties": {
        "^[A-Z][A-Za-z0-9]{0,59}$": {
          "$ref": "#/$defs/step",
          "unevaluatedProperties": false
        }
      },
      "description": "List of Steps to be performed."
    },
    "result": {
      "$ref": "#/$defs/operand",
      "unevaluatedProperties": false,
      "description": "Optional: Result to be returned"
    }
  },
  "required": ["name"],
  "if": {
    "not": {
      "properties": {
        "dataProviderDelegation": {
          "not": {}
        }
      }
    }
  },
  "then": {
    "properties": {
      "steps": {
        "maxProperties": 1,
        "patternProperties": {
          "^[A-Z][A-Za-z0-9]{0,59}$": {
            "properties": {
              "commandType": {
                "type": "string",
                "enum": ["LLM"]
              }
            }
          }
        }
      }
    }
  },
  "else": {
    "required": ["steps"]
  },
  "unevaluatedProperties": false,
  "$defs": {
    "step": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "commandType": {
              "type": "string",
              "enum": ["Predefined", "LLM", "Custom", "PAL"],
              "description": "Predefined: Call to one of the BaseCommands (e.g. AddDimension, FilterOnDimension, ...). Custom: Call to another JSON-based Command of the same Booklet."
            },
            "commandName": {
              "type": "string",
              "pattern": "^[A-Z_][A-Za-z0-9_]{0,59}$",
              "description": "Name of the Command to be called."
            },
            "parameters": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/operand",
                "unevaluatedProperties": false
              },
              "description": "List of Parameter to be passed to the called Command."
            },
            "runHidden": {
              "type": "boolean",
              "description": "Execute this subcommand asynchronously in the background."
            }
          },
          "required": ["commandType", "commandName"],
          "if": {
            "properties": {
              "commandType": {
                "const": "Custom"
              }
            }
          },
          "then": {},
          "else": {
            "properties": {
              "runHidden": {
                "not": {}
              }
            }
          },
          "unevaluatedProperties": false,
          "description": "Either a Predefined BaseCommand or JSON-based Command of the same Booklet."
        },
        {
          "type": "object",
          "minProperties": 2,
          "properties": {
            "if": {
              "type": "object",
              "properties": {
                "leftOperand": {
                  "$ref": "#/$defs/operand",
                  "unevaluatedProperties": false
                },
                "operator": {
                  "type": "string",
                  "enum": ["eq", "isInitial", "gt", "ge", "le", "lt"],
                  "default": "eq"
                },
                "rightOperand": {
                  "$ref": "#/$defs/operand",
                  "unevaluatedProperties": false
                }
              },
              "required": ["leftOperand", "operator"],
              "if": {
                "properties": {
                  "operator": {
                    "const": "isInitial"
                  }
                }
              },
              "then": {
                "properties": {
                  "rightOperand": {
                    "not": {}
                  }
                }
              },
              "else": {
                "required": ["rightOperand"]
              },
              "unevaluatedProperties": false,
              "description": "Condition to be checked."
            },
            "then": {
              "$ref": "#/$defs/step",
              "unevaluatedProperties": false,
              "description": "Executed if condition is fulfilled."
            },
            "else": {
              "$ref": "#/$defs/step",
              "unevaluatedProperties": false,
              "description": "Executed if condition is not fulfilled."
            }
          },
          "required": ["if"],
          "unevaluatedProperties": false,
          "description": "Conditional step. One or both of 'then' and 'else' must be specified."
        }
      ]
    },
    "operand": {
      "description": "Either a fixed 'value', a 'ref' to a Constant/Parameter or the result of a pevious 'step'.",
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "ref": {
              "type": "string",
              "pattern": "^[A-Z][A-Za-z0-9]{0,59}$",
              "description": "Reference to a predefined parameter/constant"
            }
          },
          "required": ["ref"],
          "unevaluatedProperties": false
        },
        {
          "type": "object",
          "properties": {
            "value": {
              "type": "string",
              "description": "A fix value entered directly"
            }
          },
          "required": ["value"],
          "unevaluatedProperties": false
        },
        {
          "type": "object",
          "properties": {
            "step": {
              "type": "string",
              "pattern": "^[A-Z][A-Za-z0-9]{0,59}$",
              "description": "Refernce to a step of the same file."
            },
            "path": {
              "type": "string",
              "pattern": "^([A-Za-z0-9_]{1,60}/)*([A-Za-z0-9_]{1,60})$",
              "description": "Path to the result-property."
            }
          },
          "required": ["step"],
          "unevaluatedProperties": false
        }
      ]
    },
    "operandRef": {
      "allOf": [
        {
          "$ref": "#/$defs/operand"
        },
        {
          "properties": {
            "step": {
              "not": {}
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "parameter": {
      "type": "object",
      "properties": {
        "semanticType": {
          "type": "string",
          "enum": [
            "Variable",
            "Dimension",
            "Measure",
            "StructureMember",
            "MemberKey",
            "Axis",
            "Direction",
            "Identifier",
            "Number",
            "Boolean"
          ]
        },
        "dimension": {
          "$ref": "#/$defs/operandRef"
        },
        "variable": {
          "$ref": "#/$defs/operandRef"
        }
      },
      "required": ["semanticType"],
      "if": {
        "properties": {
          "semanticType": {
            "const": "MemberKey"
          }
        }
      },
      "then": {
        "minProperties": 2,
        "maxProperties": 2
      },
      "else": {
        "properties": {
          "dimension": {
            "not": {}
          },
          "variable": {
            "not": {}
          }
        }
      }
    }
  }
}
